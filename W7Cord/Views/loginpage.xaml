<phone:PhoneApplicationPage
    x:Class="W7Cord.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone.Controls.Toolkit"
    FontFamily="{StaticResource PhoneFontFamilyNormal}"
    FontSize="{StaticResource PhoneFontSizeNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    SupportedOrientations="Portrait" Orientation="Portrait"
    mc:Ignorable="d"
    shell:SystemTray.IsVisible="True">

    <toolkit:TransitionService.NavigationInTransition>
        <toolkit:NavigationInTransition>
            <toolkit:NavigationInTransition.Backward>
                <toolkit:TurnstileTransition Mode="BackwardIn"/>
            </toolkit:NavigationInTransition.Backward>
            <toolkit:NavigationInTransition.Forward>
                <toolkit:TurnstileTransition Mode="ForwardIn"/>
            </toolkit:NavigationInTransition.Forward>
        </toolkit:NavigationInTransition>
    </toolkit:TransitionService.NavigationInTransition>
    <toolkit:TransitionService.NavigationOutTransition>
        <toolkit:NavigationOutTransition>
            <toolkit:NavigationOutTransition.Backward>
                <toolkit:TurnstileTransition Mode="BackwardOut"/>
            </toolkit:NavigationOutTransition.Backward>
            <toolkit:NavigationOutTransition.Forward>
                <toolkit:TurnstileTransition Mode="ForwardOut"/>
            </toolkit:NavigationOutTransition.Forward>
        </toolkit:NavigationOutTransition>
    </toolkit:TransitionService.NavigationOutTransition>

    <phone:PhoneApplicationPage.Resources>
        <ExponentialEase x:Key="EaseEnter" EasingMode="EaseOut" Exponent="7" />

        <Storyboard x:Key="ShowLoginStoryboard" 
                    x:Name="ShowLoginStoryboard">
            <DoubleAnimation
                EasingFunction="{StaticResource EaseEnter}"
                Storyboard.TargetName="MainTransform"
                Storyboard.TargetProperty="Y"
                From="200"
                To="0"
                Duration="00:00:00.50" />
            <DoubleAnimation
                EasingFunction="{StaticResource EaseEnter}"
                Storyboard.TargetName="LayoutRoot"
                Storyboard.TargetProperty="Opacity"
                To="1"
                Duration="00:00:00.50" />
        </Storyboard>


        
    </phone:PhoneApplicationPage.Resources>

    <Grid x:Name="LayoutRoot"
          VerticalAlignment="Center" 
          Background="Transparent"
          Opacity="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.RenderTransform>
            <TranslateTransform x:Name="MainTransform" Y="200" />
        </Grid.RenderTransform>


        <StackPanel Grid.Row="0" Margin="12,0,0,0">
            <Viewbox Width="110" Margin="12,0,0,0" HorizontalAlignment="Left" CacheMode="BitmapCache">
                <Image Source="/Assets/logo.png"
                       Width="1000"
                       Height="220"
                       Stretch="UniformToFill"
                       Margin="-50,32,0,-16"
                       CacheMode="BitmapCache"/>
            </Viewbox>
            <TextBlock Text="sign in" Margin="12,0,0,0" Style="{StaticResource PhoneTextTitle1Style}"/>
        </StackPanel>


        <StackPanel x:Name="ContentPanel" Grid.Row="1" Margin="12">

            <Grid>
                <PasswordBox x:Name="TokenTextBox"
                             GotFocus="TokenTextBox_GotFocus"
                             LostFocus="TokenTextBox_LostFocus"
                             Background="#33FFFFFF"
                             Foreground="White"
                             Height="72"
                             FontSize="20"/>
                <TextBlock x:Name="PasswordWatermark"
                           VerticalAlignment="Center"
                           Margin="18,0"
                           Text="Enter your Token"
                           FontSize="20"
                           Foreground="#66FFFFFF"
                           IsHitTestVisible="False"/>
            </Grid>


            <Button x:Name="LoginButton" 
                    Click="LoginButton_Click"
                    Content="login"
                    Background="{StaticResource PhoneAccentBrush}"
                    Foreground="White"
                    Height="72"
                    Margin="0,20,0,12"
                    FontSize="22"/>


            <Button x:Name="TestProxyButton" 
                    Content="test bridge"
                    Click="TestProxyButton_Click"
                    Background="#33FFFFFF"
                    Foreground="White"
                    Height="60"
                    Margin="0,0,0,20"
                    FontSize="18"/>


            <TextBlock x:Name="ErrorText" 
                       Text=""
                       Foreground="{StaticResource PhoneRedAccentBrush}"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"
                       Visibility="Collapsed"/>


            <TextBlock Text="how to get token:" FontSize="16" Margin="0,20,0,8" Foreground="{StaticResource PhoneSubtleBrush}"/>
            <TextBlock Text="1. Open Discord in browser" FontSize="14" Foreground="{StaticResource PhoneSubtleBrush}"/>
            <TextBlock Text="2. Press F12 → Console" FontSize="14" Foreground="{StaticResource PhoneSubtleBrush}"/>
            <TextBlock Text="3. Type: (webpackChunkdiscord_app.push([[''],{},e=>{m=[];for(let c in e.c)m.push(e.c[c])}]),m).find(m=>m?.exports?.default?.getToken!==undefined).exports.default.getToken()" FontSize="11" Foreground="{StaticResource PhoneSubtleBrush}" TextWrapping="Wrap"/>
            <TextBlock Text="4. Copy the token" FontSize="14" Foreground="{StaticResource PhoneSubtleBrush}" Margin="0,8,0,0"/>
        </StackPanel>

        <Border x:Name="TestBrowserHost" Grid.Row="2" Width="0" Height="0" Margin="0,0,0,0" Visibility="Collapsed"/>
    </Grid>
</phone:PhoneApplicationPage>