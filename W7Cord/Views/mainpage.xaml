<phone:PhoneApplicationPage
    x:Class="W7Cord.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:controls="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone.Controls"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    FontFamily="{StaticResource PhoneFontFamilyNormal}"
    FontSize="{StaticResource PhoneFontSizeNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    SupportedOrientations="Portrait" Orientation="Portrait"
    Loaded="PhoneApplicationPage_Loaded" mc:Ignorable="d" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" d:DesignHeight="800" d:DesignWidth="480">

    <Grid x:Name="LayoutRoot" Background="{StaticResource PhoneBackgroundBrush}">
        <controls:Panorama>
            <controls:Panorama.Title>
                <Image Source="/Assets/logo.png"
                       Width="1000"
                       Height="220"
                       Stretch="UniformToFill"
                       Margin="-50,32,0,-16"
                       CacheMode="BitmapCache"/>
            </controls:Panorama.Title>

            <controls:PanoramaItem Header="servers">
                <ListBox x:Name="GuildsList" ItemsSource="{Binding Guilds}" SelectionChanged="GuildsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="12,0,12,12" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                               
                                <Image Source="{Binding IconUrl}" Width="80" Height="80" Margin="0,0,16,0" Stretch="UniformToFill"/>

                                
                                <TextBlock Text="{Binding Name}" 
                                           Grid.Column="1" 
                                           VerticalAlignment="Center" 
                                           FontFamily="Segoe WP Black" 
                                           FontWeight="ExtraBold" 
                                           FontSize="28" 
                                           Foreground="White"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </controls:PanoramaItem>

            <controls:PanoramaItem Header="people">
                <ListBox x:Name="DMsList" ItemsSource="{Binding DirectMessages}" SelectionChanged="DMsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="12,0,12,12" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>


                                <Image Source="{Binding IconUrl}" Width="80" Height="80" Margin="0,0,16,0" Stretch="UniformToFill"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">

                                    <TextBlock Text="{Binding Name}" 
                                               FontFamily="Segoe WP Black" 
                                               FontWeight="ExtraBold" 
                                               FontSize="24" 
                                               Foreground="White"/>

                                    <TextBlock Text="click to chat" 
                                               FontSize="14" 
                                               Foreground="{StaticResource PhoneSubtleBrush}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </controls:PanoramaItem>

            <controls:PanoramaItem Header="settings">
                <StackPanel Margin="12,0,12,0">
                    <Button x:Name="RefreshButton" Content="refresh" Click="RefreshButton_Click" Background="{StaticResource PhoneAccentBrush}" Foreground="White" Height="72" Margin="0,20,0,12"/>
                    <Button x:Name="SignOutButton" Content="sign out" Click="SignOutButton_Click" Background="{StaticResource PhoneRedAccentBrush}" Foreground="White" Height="72"/>
                    <TextBlock Text="7evencord | Made by ChockingNetDude" />
                    <TextBlock Text="Support: t.me/W7Mobile" />
                </StackPanel>
            </controls:PanoramaItem>
        </controls:Panorama>

        <Border x:Name="WebBrowserHost" Width="0" Height="0" Visibility="Collapsed"/>
    </Grid>
</phone:PhoneApplicationPage>